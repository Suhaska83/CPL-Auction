rules_version = '2';

// CPLAuction — Firebase Storage rules.
// Paste this into Firebase console → Storage → Rules → Publish.
// Path model:
//   /logos/*    — team crest / franchise logos
//   /players/*  — player photos
//   /misc/*     — anything else uploaded via <ImageUpload/>
service firebase.storage {
  match /b/{bucket}/o {
    // Anyone can view (needed so spectators see logos + photos).
    match /{allPaths=**} {
      allow read: if true;
    }
    // Only authenticated users (signed-in admins) can upload.
    // Cap file size at 5 MB and require an image content-type.
    match /{folder}/{file} {
      allow write:
        if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      // Allow admins to also delete their uploads (contentType is null on delete).
      allow delete: if request.auth != null;
    }
  }
}
